# Copiez en .env ou définissez dans le terminal / sur l'hébergeur

# URL accessible depuis Internet (obligatoire hors réseau local)
# Ex. tunnel ngrok : https://xxxx.ngrok-free.app
# Ex. Render       : laisser vide (RENDER_EXTERNAL_URL est auto)
PUBLIC_URL=

# Secret pour signer les QR (changez en production)
QR_SECRET=changez-moi-en-production

PORT=3000
