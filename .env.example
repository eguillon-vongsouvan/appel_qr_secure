# Copiez en .env ou définissez dans le terminal / sur Render

PUBLIC_URL=
QR_SECRET=changez-moi-en-production
PORT=3000

# Géolocalisation (obligatoire en prod pour émarger sur place)
# Désactiver : GEOFENCE_ENABLED=0
GEOFENCE_ENABLED=1
SCHOOL_LATITUDE=48.8566
SCHOOL_LONGITUDE=2.3522
GEOFENCE_RADIUS_METERS=150
