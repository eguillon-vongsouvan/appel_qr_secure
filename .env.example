# Copiez en .env — mode EN LIGNE obligatoire (pas d'IP locale dans les QR)

# URL HTTPS publique (Render, ngrok, domaine perso)
PUBLIC_URL=https://votre-app.onrender.com

# Node
QR_SECRET=changez-moi-en-production
PORT=3000

# Python (prof / Google OAuth) — même URL que PUBLIC_URL
PUBLIC_BASE_URL=https://votre-app.onrender.com
APP_SECRET=changez-moi-en-production

# Géolocalisation — scan à moins de 200 m du cours (tout réseau : 4G, Wi‑Fi, etc.)
GEOFENCE_ENABLED=1
SCHOOL_LATITUDE=48.8566
SCHOOL_LONGITUDE=2.3522
GEOFENCE_RADIUS_METERS=200
